# Environment Variables
# Add your API keys here. Without these, the app uses realistic fallback data.

# NewsAPI.org API Key (https://newsapi.org)
# NEWSAPI_KEY=

# GNews API Key (https://gnews.io)
# GNEWS_KEY=

# Anthropic API Key for AI-powered summaries (https://console.anthropic.com)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Groq API Key for AI-powered clustering (https://groq.com)
# GROQ_API_KEY=your_groq_key_here

# Redis URL for caching (optional - if not set, caching is disabled)
# Examples:
#   redis://localhost:6379
#   rediss://user:password@your-redis-instance:6379
# REDIS_URL=redis://localhost:6379
